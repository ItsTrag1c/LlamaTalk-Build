{
  "name": "clankbuild",
  "version": "2.5.7",
  "author": "ItsTrag1c",
  "type": "module",
  "bin": {
    "clankbuild": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "build:bundle": "esbuild index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs",
    "build:exe": "node scripts/build-exe.js",
    "build": "npm run build:bundle && npm run build:exe",
    "changelog-pdf": "node scripts/make-changelog-pdf.js"
  },
  "dependencies": {
    "grammy": "^1.35.0",
    "clankbuild-engine": "file:./engine"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "pdfkit": "^0.17.2",
    "pkg": "^5.8.1"
  }
}
